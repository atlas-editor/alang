fn main() {
    a := 12

    match a {
        1 => {
            println(a, "== 1")
        }
        2 => {
            println(a, "== 2")
        }
        _ => {
            println(a "!= 1 nor 2")
        }
    }


    // result type res[T] (akin to Rust's Result<T, E>), can contain ok(T) or err(...)
    b res[int] := ok(13)
    println(b)

    c res[int] := err("undefined")

    match c {
        ok(val) => {
            // val has type int
            println("c contains a non-error value", val)
        }
        err(e) => {
            println("c contains error value", e)
        }
    }
}
